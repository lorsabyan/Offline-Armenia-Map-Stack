# Default configuration values for the offline Armenia map stack
# Copy to .env and adjust values for your deployment:
#   cp .env.example .env

OSM_PBF_URL=https://download.geofabrik.de/asia/armenia-latest.osm.pbf
OSM_POLY_URL=https://download.geofabrik.de/asia/armenia.poly
# Interval in seconds for periodic data refresh
DATA_UPDATE_INTERVAL=86400
# OSRM tuning
OSRM_PROFILE=car
OSRM_MAX_MATCHING_SIZE=100
OSRM_MAX_TABLE_SIZE=1000
# Nominatim (internal backend for Photon import) — CHANGE IN PRODUCTION
NOMINATIM_PASSWORD=nominatim
# Photon geocoder
PHOTON_LANGUAGES=hy
PHOTON_COUNTRY_CODES=am
# JVM heap sizing — tune for your server's available RAM
PHOTON_IMPORT_HEAP=1g
PHOTON_SERVE_HEAP=512m
# Manager API security (set a strong token for production)
UPDATE_TOKEN=
# Rate limiting: min seconds between update requests per service
RATE_LIMIT_SECONDS=60
# Trigger polling interval (seconds) for OSRM and Photon services
POLL_INTERVAL=30
